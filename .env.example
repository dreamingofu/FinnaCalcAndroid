# Copy these into assets/.env and fill the blanks with the web app's PUBLIC values.
# (assets/.env is what actually gets bundled; this file is documentation.)

# Base URL of the existing Next.js backend the app calls.
API_BASE_URL=https://finnacalc.com

# Supabase project URL + anon (publishable) key — same as the web client.
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Google OAuth *web* client ID (used as serverClientId for native Google sign-in).
GOOGLE_WEB_CLIENT_ID=
