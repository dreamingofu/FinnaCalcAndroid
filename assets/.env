# FinnaCalc Android runtime configuration (bundled as an asset).
# These are PUBLIC client values only — never put server secrets here.
# Supabase anon keys are designed to ship in clients (RLS protects data).
# Fill SUPABASE_URL / SUPABASE_ANON_KEY / GOOGLE_WEB_CLIENT_ID with the same
# public values the web app uses, then rebuild.

API_BASE_URL=https://finnacalc.com
SUPABASE_URL=
SUPABASE_ANON_KEY=
GOOGLE_WEB_CLIENT_ID=
